# Identity of this machine — used by remote-sessions.sh to hide local device
set-environment -g REMOTE_SELF mini

# Quick action menu — script handles conditional remote section
bind m run-shell "bash ~/dotfiles/scripts/tmux/tmux-menu.sh"

# Kawakawa session management (Mac mini-local)
bind K display-popup -w 40 -h 15 -T " Remote Sessions " -E "bash ~/dotfiles/scripts/tmux/remote-sessions.sh"

